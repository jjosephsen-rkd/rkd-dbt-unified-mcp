# Copy this to .env and fill in real values for local dev
# NEVER commit .env

# Set to "local" to use env vars instead of AWS Secrets Manager
SECRET_BACKEND=local

# Option A — single personal API token that covers all projects (easiest for local dev)
# DBT_TOKEN_DEFAULT=dbtc_your_personal_token_here

# Option B — per-client service tokens (recommended for production)
# DBT_TOKEN_FCCTX=dbtc_your_token_here
# DBT_TOKEN_BCMNY=dbtc_your_token_here
# DBT_TOKEN_HFBTX=dbtc_your_token_here
# DBT_TOKEN_NMSS=dbtc_your_token_here
# DBT_TOKEN_FTC=dbtc_your_token_here
# DBT_TOKEN_ABS=dbtc_your_token_here
# DBT_TOKEN_BFF=dbtc_your_token_here
# Add one line per client

# Per-client tokens take precedence over DBT_TOKEN_DEFAULT when both are set.
